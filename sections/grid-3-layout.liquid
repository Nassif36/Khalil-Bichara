{% liquid
	assign section_heading = section.settings.heading
%}

<section class="grid-3-layout section-{{ section.id }}">
	<div class="grid-3-layout__inner">
		{% if section_heading != blank %}
			<div class="grid-3-layout__header">
				<h2 class="grid-3-layout__heading">{{ section_heading }}</h2>
			</div>
		{% endif %}

		<div class="grid-3-layout__grid" role="list">
			{% for block in section.blocks %}
				{% liquid
					assign product = block.settings.product
					if request.visual_preview_mode and product == blank
						assign product = collections.all.products.first
					endif
				%}

				<article class="grid-3-layout__item" role="listitem" {{ block.shopify_attributes }}>
					{% if product != blank %}
						{% assign featured_media = product.featured_media %}
						{% assign variant = product.selected_or_first_available_variant %}

						<a href="{{ product.url }}" class="grid-3-layout__media-link">
							<div class="grid-3-layout__media">
								{% if featured_media != blank %}
									{{
										featured_media
										| image_url: width: 900
										| image_tag:
											class: 'grid-3-layout__image',
											loading: 'lazy',
											widths: '320, 480, 720, 900',
											sizes: '(min-width: 990px) 33vw, 50vw',
											alt: featured_media.alt | default: product.title | escape
									}}
								{% else %}
									{{ 'product-1' | placeholder_svg_tag: 'grid-3-layout__image grid-3-layout__image--placeholder' }}
								{% endif %}
							</div>
						</a>

						<div class="grid-3-layout__content">
							<div class="grid-3-layout__copy">
								<p class="grid-3-layout__vendor">{{ product.vendor }}</p>
								<h3 class="grid-3-layout__title">
									<a href="{{ product.url }}">{{ product.title }}</a>
								</h3>
								<div class="grid-3-layout__price">
									  {% render 'price', product_resource: product, show_unit_price: true %}
								</div>
							</div>

							<div class="grid-3-layout__actions">
								{% render 'quick-add', product: product, section_id: section.id, block: block %}

								{% if variant != blank and variant.available == false %}
									<p class="grid-3-layout__status">{{ 'products.product.sold_out' | t }}</p>
								{% endif %}
							</div>
						</div>
					{% else %}
						<div class="grid-3-layout__media grid-3-layout__media--placeholder">
							{{ 'product-1' | placeholder_svg_tag: 'grid-3-layout__image grid-3-layout__image--placeholder' }}
						</div>
						<div class="grid-3-layout__content">
							  <h3 class="grid-3-layout__title">Product title</h3>
							  <p class="grid-3-layout__status">Select a product for this block.</p>
						</div>
					{% endif %}
				</article>
			{% endfor %}
		</div>
	</div>
</section>

{% stylesheet %}
	.grid-3-layout {
		padding-block: var(--padding-xl);
	}

	.grid-3-layout__inner {
		width: min(100% - 3rem, var(--page-width, 1400px));
		margin-inline: auto;
		display: grid;
		gap: var(--padding-lg);
	}

	.grid-3-layout__header {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: var(--padding-sm);
	}

	.grid-3-layout__heading {
		margin: 0;
	}

	.grid-3-layout__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--padding-md);
	}

	.grid-3-layout__item {
		display: grid;
		grid-template-rows: auto 1fr;
		min-width: 0;
		background: rgb(var(--color-background));
		border: 1px solid rgba(var(--color-foreground-rgb), 0.08);
		border-radius: var(--style-border-radius-inputs);
		overflow: clip;
	}

	.grid-3-layout__media-link {
		display: block;
		color: inherit;
		text-decoration: none;
	}

	.grid-3-layout__media {
		aspect-ratio: 4 / 5;
		background: rgba(var(--color-foreground-rgb), 0.04);
	}

	.grid-3-layout__image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.grid-3-layout__image--placeholder {
		background: rgba(var(--color-foreground-rgb), 0.04);
	}

	.grid-3-layout__content {
		display: grid;
		align-content: space-between;
		gap: var(--padding-md);
		padding: var(--padding-md);
	}

	.grid-3-layout__copy {
		display: grid;
		gap: 0.5rem;
	}

	.grid-3-layout__vendor {
		margin: 0;
		opacity: 0.65;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.75rem;
	}

	.grid-3-layout__title {
		margin: 0;
		font: inherit;
		font-size: clamp(1rem, 0.9rem + 0.2vw, 1.125rem);
	}

	.grid-3-layout__title a {
		color: inherit;
		text-decoration: none;
	}

	.grid-3-layout__price {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		align-items: baseline;
	}

	.grid-3-layout__actions {
		display: grid;
		gap: 0.5rem;
	}

	.grid-3-layout__actions .quick-add,
	.grid-3-layout__actions .quick-add__product-form-component,
	.grid-3-layout__actions .shopify-product-form {
		width: 100%;
	}

	.grid-3-layout__actions .quick-add__button {
		width: 100%;
		justify-content: center;
	}

	.grid-3-layout__status {
		margin: 0;
		opacity: 0.7;
		font-size: 0.875rem;
	}

	@media screen and (min-width: 990px) {
		.grid-3-layout__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
{% endstylesheet %}

{% schema %}
{
	"name": "Grid 3 layout",
	"tag": "section",
	"class": "section",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Featured products"
		}
	],
	"blocks": [
		{
			"type": "product",
			"name": "Product",
			"settings": [
				{
					"type": "product",
					"id": "product",
					"label": "Product"
				}
			]
		}
	],
	"max_blocks": 12,
	"presets": [
		{
			"name": "Grid 3 layout",
			"blocks": [
				{ "type": "product" },
				{ "type": "product" },
				{ "type": "product" }
			]
		}
	]
}
{% endschema %}
