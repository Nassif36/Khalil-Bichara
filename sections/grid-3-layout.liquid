{% liquid
	assign section_heading = section.settings.heading
%}

<section class="grid-3-layout section-{{ section.id }}">
	<div class="grid-3-layout__inner">
		{% if section_heading != blank %}
			<div class="grid-3-layout__header">
				<h2 class="grid-3-layout__heading">{{ section_heading }}</h2>
			</div>
		{% endif %}

		<div class="grid-3-layout__grid" role="list">
			{% for block in section.blocks %}
				{% liquid
					assign product = block.settings.product
					if request.visual_preview_mode and product == blank
						assign product = collections.all.products.first
					endif
				%}

				<article class="grid-3-layout__item" role="listitem" {{ block.shopify_attributes }}>
					{% if product != blank %}
						{% assign featured_media = product.featured_media %}
						{% assign variant = product.selected_or_first_available_variant %}

						<a href="{{ product.url }}" class="grid-3-layout__media-link">
							<div class="grid-3-layout__media">
								{% if featured_media != blank %}
									{{
										featured_media
										| image_url: width: 900
										| image_tag:
											class: 'grid-3-layout__image',
											loading: 'lazy',
											widths: '320, 480, 720, 900',
											sizes: '(min-width: 990px) 33vw, 50vw',
											alt: featured_media.alt | default: product.title | escape
									}}
								{% else %}
									{{ 'product-1' | placeholder_svg_tag: 'grid-3-layout__image grid-3-layout__image--placeholder' }}
								{% endif %}
							</div>
						</a>

						<div class="grid-3-layout__actions">
							<quick-add-component
								class="grid-3-layout__quick-add"
								data-product-title="{{ product.title }}"
								data-quick-add-button="choose"
								data-product-options-count="{{ product.options.size }}"
								data-product-url="{{ product.url }}"
							>
								<button
									class="grid-3-layout__quick-add-button"
									type="button"
									name="add"
									on:click="quick-add-component/handleClick"
									aria-label="{{ 'actions.choose' | t }} {{ product.title | escape }}"
									{% if variant != blank and variant.available == false %}
										disabled
										aria-disabled="true"
									{% endif %}
								>
									+
								</button>
							</quick-add-component>
						</div>
					{% else %}
						<div class="grid-3-layout__media grid-3-layout__media--placeholder">
							{{ 'product-1' | placeholder_svg_tag: 'grid-3-layout__image grid-3-layout__image--placeholder' }}
						</div>
					{% endif %}
				</article>
			{% endfor %}
		</div>
	</div>
</section>

{% stylesheet %}
	.grid-3-layout {
		padding-block: var(--padding-xl);
	}

	.grid-3-layout__inner {
		margin-inline: auto;
		display: grid;
		gap: var(--padding-lg);
	}

	.grid-3-layout__header {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: var(--padding-sm);
	}

	.grid-3-layout__heading {
		margin: 0;
	}

	.grid-3-layout__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--padding-md);
	}

	.grid-3-layout__item {
		position: relative;
		min-width: 0;
		background: rgb(var(--color-background));
		border: 1px solid rgba(var(--color-foreground-rgb), 0.08);
		border-radius: var(--style-border-radius-inputs);
		overflow: clip;
		max-height: 400px;
	}

	.grid-3-layout__media-link {
		display: block;
		color: inherit;
		text-decoration: none;
	}

	.grid-3-layout__media {
		aspect-ratio: 4 / 5;
		background: rgba(var(--color-foreground-rgb), 0.04);
	}

	.grid-3-layout__image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.grid-3-layout__image--placeholder {
		background: rgba(var(--color-foreground-rgb), 0.04);
	}

	.grid-3-layout__actions {
		position: absolute;
		right: 0.75rem;
		bottom: 0.75rem;
		z-index: 2;
	}

	.grid-3-layout__quick-add {
		display: block;
	}

	.grid-3-layout__quick-add-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 0;
		border-radius: 999px;
		background: #ffffff;
		color: #000000;
		font-size: 1.75rem;
		line-height: 1;
		cursor: pointer;
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
		transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
	}

	.grid-3-layout__quick-add-button:hover,
	.grid-3-layout__quick-add-button:focus-visible {
		background: #f4db3f;
		color: #000000;
		transform: translateY(-1px);
	}

	.grid-3-layout__quick-add-button:disabled {
		opacity: 0.55;
		cursor: not-allowed;
		transform: none;
	}

	@media screen and (min-width: 990px) {
		.grid-3-layout__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
{% endstylesheet %}

{% schema %}
{
	"name": "Grid 3 layout",
	"tag": "section",
	"class": "section",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Featured products"
		}
	],
	"blocks": [
		{
			"type": "product",
			"name": "Product",
			"settings": [
				{
					"type": "product",
					"id": "product",
					"label": "Product"
				}
			]
		}
	],
	"max_blocks": 12,
	"presets": [
		{
			"name": "Grid 3 layout",
			"blocks": [
				{ "type": "product" },
				{ "type": "product" },
				{ "type": "product" }
			]
		}
	]
}
{% endschema %}
