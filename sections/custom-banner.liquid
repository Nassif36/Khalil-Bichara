{% liquid
	assign top_logo = section.settings.top_logo
	assign top_text = section.settings.top_text
	assign top_cta_text = section.settings.top_cta_text
	assign top_cta_link = section.settings.top_cta_link
	assign background_image = section.settings.background_image
	assign heading = section.settings.heading
	assign body_text = section.settings.body_text
	assign main_cta_text = section.settings.main_cta_text
	assign main_cta_link = section.settings.main_cta_link
	assign bottom_text = section.settings.bottom_text
%}

<div
	class="custom-banner"
	{% if background_image != blank %}
		style="--custom-banner-background-image: url('{{ background_image | image_url: width: 2400 }}');"
	{% endif %}
>
	<div class="custom-banner__surface">
		<div class="custom-banner__top-bar">
			<div class="custom-banner__top-logo">
				{% if top_logo != blank %}
					{{
						top_logo
						| image_url: width: 320
						| image_tag:
							class: 'custom-banner__logo-image',
							loading: 'lazy',
							widths: '120, 160, 240, 320',
							alt: top_logo.alt | default: shop.name | escape
					}}
				{% else %}
					<span class="custom-banner__logo-placeholder">{{ shop.name }}</span>
				{% endif %}
			</div>

			{% if top_text != blank %}
				<p class="custom-banner__top-text">{{ top_text }}</p>
			{% else %}
				<div></div>
			{% endif %}

			{% if top_cta_text != blank %}
				<a
					class="custom-banner__top-cta"
					{% if top_cta_link != blank %}
						href="{{ top_cta_link }}"
					{% else %}
						role="link"
						aria-disabled="true"
					{% endif %}
				>
					<span class="custom-banner__cta-label">{{ top_cta_text }}</span>
					<span class="custom-banner__cta-icon" aria-hidden="true">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
				</a>
			{% else %}
				<div></div>
			{% endif %}
		</div>

		<div class="custom-banner__hero">
			<div class="custom-banner__content">
				{% if heading != blank %}
					<h2 class="custom-banner__heading">{{ heading }}</h2>
				{% endif %}

				{% if body_text != blank %}
					<p class="custom-banner__body">{{ body_text }}</p>
				{% endif %}

				{% if main_cta_text != blank %}
					<a
						class="custom-banner__main-cta"
						{% if main_cta_link != blank %}
							href="{{ main_cta_link }}"
						{% else %}
							role="link"
							aria-disabled="true"
						{% endif %}
					>
								<span class="custom-banner__cta-label">{{ main_cta_text }}</span>
							<span class="custom-banner__cta-icon" aria-hidden="true">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
					</a>
				{% endif %}
			</div>
		</div>

		{% if main_cta_text != blank %}
			<div class="custom-banner__mobile-cta-wrap">
				<a
					class="custom-banner__main-cta custom-banner__main-cta--mobile"
					{% if main_cta_link != blank %}
						href="{{ main_cta_link }}"
					{% else %}
						role="link"
						aria-disabled="true"
					{% endif %}
				>
					<span class="custom-banner__cta-label">{{ main_cta_text }}</span>
					<span class="custom-banner__cta-icon" aria-hidden="true">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
				</a>
			</div>
		{% endif %}

		{% if bottom_text != blank %}
			<div class="custom-banner__bottom-bar">
				<p class="custom-banner__bottom-text">{{ bottom_text }}</p>
			</div>
		{% endif %}
	</div>
</div>

{% stylesheet %}

	.custom-banner__surface {
		background-color: #f1f1f1;
		background-image: linear-gradient(rgba(0, 0, 0, 0.16), rgba(0, 0, 0, 0.16)), var(--custom-banner-background-image);
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
	}

	.custom-banner__top-bar,
	.custom-banner__bottom-bar {
		background: #d9d9d9;
		padding: 1rem 1.5rem;
	}

	.custom-banner__top-bar {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
	}

	.custom-banner__top-logo {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		min-width: 0;
	}

	.custom-banner__logo-image {
		display: block;
		width: auto;
		height: auto;
		max-width: min(180px, 100%);
	}

	.custom-banner__logo-placeholder {
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.custom-banner__top-text,
	.custom-banner__bottom-text {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.4;
		text-align: center;
	}

	.custom-banner__top-cta,
	.custom-banner__main-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		position: relative;
		overflow: hidden;
		isolation: isolate;
		padding: 0.95rem 1.6rem;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 0.85rem;
		font-weight: 700;
		border-radius: 0;
		min-height: 52px;
		max-width: 205px;
		width: 100%;
		transition: color 0.35s ease;
	}

	.custom-banner__top-cta::before,
	.custom-banner__main-cta::before {
		content: '';
		position: absolute;
		inset: 0;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.35s ease;
		z-index: 0;
	}

	.custom-banner__cta-label,
	.custom-banner__cta-icon {
		position: relative;
		z-index: 1;
	}

	.custom-banner__top-cta {
		justify-self: end;
		background: #f4db3f;
		color: #000000;
	}

	.custom-banner__top-cta::before {
		background: #000000;
	}

	.custom-banner__main-cta {
		background: #000000;
		color: #ffffff;
		position: relative;
	}

	.custom-banner__main-cta::before {
		background: #f4db3f;
	}

	.custom-banner__top-cta:hover,
	.custom-banner__top-cta:focus-visible  {
		color: #ffffff;
	}

	.custom-banner__main-cta:hover,
	.custom-banner__main-cta:focus-visible {
		color: #000000;
	}

	.custom-banner__top-cta:hover::before,
	.custom-banner__top-cta:focus-visible::before,
	.custom-banner__main-cta:hover::before,
	.custom-banner__main-cta:focus-visible::before {
		transform: scaleX(1);
	}

	.custom-banner__cta-icon {
		display: inline-flex;
		width: 1.8rem;
		line-height: 0;
		flex-shrink: 0;
		color: currentColor;
		transition: opacity 0.2s ease;
		position: absolute;
    bottom: 4%;
    right: 7%;
    top: 0;
	}

	.custom-banner__top-cta:hover .custom-banner__cta-icon,
	.custom-banner__top-cta:focus-visible .custom-banner__cta-icon,
	.custom-banner__main-cta:hover .custom-banner__cta-icon,
	.custom-banner__main-cta:focus-visible .custom-banner__cta-icon {
		opacity: 0;
	}

	.custom-banner__cta-icon svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.custom-banner__hero {
		display: grid;
		align-items: flex-end;
		min-height: 90vh;
	}

	.custom-banner__content {
		max-width: 38rem;
		padding: clamp(1.5rem, 3vw, 2.5rem);
		background: rgba(255, 255, 255, 0.97);
		backdrop-filter: blur(6px);
		display: grid;
		gap: 1rem;
	}

	.custom-banner__heading {
		margin: 0;
		font-size: clamp(2rem, 4vw, 4rem);
		line-height: 1;
	}

	.custom-banner__body {
		margin: 0;
		font-size: 1rem;
		line-height: 1.65;
		max-width: 34rem;
	}

	.custom-banner__bottom-bar {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.custom-banner__mobile-cta-wrap {
		display: none;
	}


	

	@media screen and (max-width: 768px) {

		.custom-banner__top-bar {
			display: none;
		}

		.custom-banner__content {
			background: transparent;
			backdrop-filter: none;
			height: 100%;
			grid-template-rows: auto auto 50%;
			place-content: center;
			text-align: center;
			padding: 0;
			gap: 0;
		}

		.custom-banner__heading ,
		.custom-banner__body {
			background: #ffffff;
			padding: 1em;
		}
		.custom-banner__main-cta {
			max-height: max-content;
			margin: auto;
		}

		.custom-banner__content .custom-banner__main-cta {
			display: none;
		}

		.custom-banner__mobile-cta-wrap {
			display: flex;
			justify-content: center;
			padding: 1rem 1rem 1.5rem;
		}

		.custom-banner__main-cta--mobile {
			max-width: min(100%, 22rem);
			margin: 0;
		}

	}
{% endstylesheet %}

{% schema %}
{
	"name": "Custom banner",
	"tag": "section",
	"class": "custom-banner-section",
	"settings": [
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "image_picker",
			"id": "top_logo",
			"label": "Top logo"
		},
		{
			"type": "text",
			"id": "top_text",
			"label": "Top bar text",
			"default": "Free shipping on selected orders"
		},
		{
			"type": "text",
			"id": "top_cta_text",
			"label": "Top CTA text",
			"default": "Shop now"
		},
		{
			"type": "url",
			"id": "top_cta_link",
			"label": "Top CTA link"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Build a strong first impression"
		},
		{
			"type": "textarea",
			"id": "body_text",
			"label": "Body text",
			"default": "Use this banner to highlight a collection, launch, or promotion with a strong visual background and direct call to action."
		},
		{
			"type": "text",
			"id": "main_cta_text",
			"label": "Main CTA text",
			"default": "Explore collection"
		},
		{
			"type": "url",
			"id": "main_cta_link",
			"label": "Main CTA link"
		},
		{
			"type": "text",
			"id": "bottom_text",
			"label": "Bottom bar text",
			"default": "Designed for quick promotional messaging"
		}
	],
	"presets": [
		{
			"name": "Custom banner"
		}
	]
}
{% endschema %}
